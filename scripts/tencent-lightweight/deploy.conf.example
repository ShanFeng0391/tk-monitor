# 腾讯云一键部署配置
# 用法：cp deploy.conf.example deploy.conf  →  填写密码与 CAM 密钥  →  运行 deploy-light1.sh / deploy-light2.sh
# deploy.conf 含敏感信息，勿提交 Git（已在 .gitignore）

GIT_REPO=https://github.com/ShanFeng0391/tk-monitor.git

# 你的两台轻量（已填好）
LIGHT1_IP=81.70.169.128
LIGHT2_IP=120.53.91.39
# 本地 Windows 重装后再填；留空则 #1 仅放行 #2
LOCAL_CLIENT_IP=

APP_ROOT_LIGHT1=/opt/tk-monitor
APP_ROOT_LIGHT2=/www/wwwroot/tk-monitor

# 数据库（#1 setup-server 与 #2 .env 共用，请设强密码）
DB_PASS=
REDIS_PASS=

# 腾讯云 COS（北京）
COS_ENDPOINT=cos.ap-beijing.myqcloud.com
COS_BUCKET=tk-monitor888-1333628464
COS_SECRET_ID=
COS_SECRET_KEY=

# 应用密钥（留空则 deploy-light2 自动生成 SECRET_KEY / JWT_SECRET_KEY）
SECRET_KEY=
JWT_SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@example.com

# 第三方 API（可从旧 .env 复制，豆包/TMDB 等）
ARK_API_KEY=
TMDB_API_KEY=
