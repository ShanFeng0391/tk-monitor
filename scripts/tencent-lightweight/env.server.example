# 腾讯云轻量服务器专用 env（在轻量上跑 PG 备份 cron 时使用）
# 复制到轻量云 /opt/tiktok-monitor/.env.server 后填写
# setup-cron.sh 会读取此文件

DATABASE_URL_SYNC=postgresql://tiktok_monitor:请填写密码@127.0.0.1:5432/tiktok_monitor

MINIO_ENDPOINT=cos.ap-guangzhou.myqcloud.com
MINIO_ACCESS_KEY=请填写CAM子账号SecretId
MINIO_SECRET_KEY=请填写CAM子账号SecretKey
MINIO_BUCKET=tiktok-monitor-covers-1250000000
MINIO_SECURE=true

POSTGRES_BACKUP_ENABLED=true
POSTGRES_BACKUP_KEEP_LOCAL=3
POSTGRES_BACKUP_KEEP_REMOTE=14
POSTGRES_BACKUP_BUCKET_PREFIX=backups/postgres

LOCAL_MODE=false
DATA_DIR=/opt/tiktok-monitor/data
