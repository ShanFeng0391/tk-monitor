# PG 备份 cron 用（轻量 #1，/www/wwwroot/tk-monitor/.env.server）

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tiktok_monitor
DB_USER=tiktok_monitor
DB_PASS=你的PG密码

MINIO_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
MINIO_ACCESS_KEY=RAM子账号AccessKeyId
MINIO_SECRET_KEY=RAM子账号AccessKeySecret
MINIO_BUCKET=tiktok-monitor-covers
MINIO_SECURE=true
POSTGRES_BACKUP_BUCKET_PREFIX=backups/postgres
