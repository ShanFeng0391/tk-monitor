# ===== 应用配置 =====
APP_NAME=TikTok Monitor
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=true

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://tiktok:tiktok123@postgres:5432/tiktok_monitor
DATABASE_URL_SYNC=postgresql://tiktok:tiktok123@postgres:5432/tiktok_monitor

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== JWT =====
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== MinIO 对象存储 =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=covers
MINIO_SECURE=false

# ===== 采集配置 =====
SCRAPE_INTERVAL_MINUTES=30
SCRAPE_VIDEO_WINDOW_HOURS=30
SCRAPE_REQUEST_DELAY_MIN=3
SCRAPE_REQUEST_DELAY_MAX=10
SCRAPE_MAX_RETRIES=3
SCRAPE_RETRY_INTERVAL_MINUTES=5
SCRAPE_PROXY_URL=

# ===== 代理池（超级管理员可在后台维护 SOCKS5 列表）=====
PROXY_POOL_ENABLED=true
PROXY_POOL_REDIS_DB=1
PROXY_POOL_HEALTH_URL=https://www.tiktok.com
PROXY_POOL_BAD_TTL_SECONDS=1800
PROXY_POOL_MAX_FAIL_STREAK=3
PROXY_POOL_LOCAL_ENV_FALLBACK=true

# ===== 阈值配置 =====
VIRAL_VIEW_THRESHOLD=100000
VIRAL_GROWTH_THRESHOLD=50
HOT_LIKE_GROWTH_THRESHOLD=30

# ===== 豆包AI影视剧识别配置（火山方舟）=====
DOUBAO_ENABLED=true
ARK_API_KEY=your-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-1-5-vision-pro-32k-250115
RECOGNITION_AUTO_TRIGGER=true
RECOGNITION_BATCH_SIZE=10
RECOGNITION_MAX_RETRIES=3
RECOGNITION_COOLDOWN_HOURS=24
RECOGNITION_DAILY_BUDGET=50
RECOGNITION_CONFIDENCE_THRESHOLD=60

# TMDB 片库（真人影视元数据）
TMDB_API_KEY=your-tmdb-api-key-here

# Bangumi 番组计划（动漫元数据，无需 Key 也可搜索；NSFW 条目需 Access Token）
BANGUMI_ENABLED=true
BANGUMI_ACCESS_TOKEN=
BANGUMI_USER_AGENT=tiktok-monitor/1.0 (https://github.com/local/tiktok-monitor)

# ===== 默认管理员 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
