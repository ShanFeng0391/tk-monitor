# ===== 阿里云轻量 #2 专用（复制为 .env.hybrid 后填写）=====
# 在 /www/wwwroot/tk-monitor 使用

LOCAL_MODE=false
SERVE_FRONTEND=true
APP_ENV=production
DEBUG=false

SECRET_KEY=请替换为至少32位随机字符串
JWT_SECRET_KEY=请替换为至少32位随机字符串
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATA_DIR=data

ENABLE_API_DOCS=false
CORS_ORIGINS=https://你的域名

DATABASE_URL=postgresql+asyncpg://tiktok_monitor:PG密码@轻量1公网IP:5432/tiktok_monitor
DATABASE_URL_SYNC=postgresql://tiktok_monitor:PG密码@轻量1公网IP:5432/tiktok_monitor
REDIS_URL=redis://:Redis密码@轻量1公网IP:6379/0
PROXY_POOL_REDIS_DB=1

MINIO_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
MINIO_ACCESS_KEY=RAM子账号AccessKeyId
MINIO_SECRET_KEY=RAM子账号AccessKeySecret
MINIO_BUCKET=tiktok-monitor-covers
MINIO_SECURE=true

COMPUTE_NODE_ID=cloud2
COMPUTE_NODE_LABEL=阿里云 #2
BEAT_ENABLED_ON_NODE=true
CELERY_WORKER_NODE_PREFIX=cloud2
CLUSTER_PEER_API_URL=
CLUSTER_EXPECTED_WORKERS_LOCAL=24
CLUSTER_EXPECTED_WORKERS_CLOUD2=10
CLUSTER_NODE_LABEL_LOCAL=本地电脑
CLUSTER_NODE_LABEL_CLOUD2=阿里云 #2

CELERY_WORKER_CONCURRENCY=10
POSTGRES_BACKUP_ENABLED=false
WEB_DEPLOY_UPDATE_ENABLED=true

SCRAPE_ALLOW_MOCK=false
PROXY_POOL_LOCAL_ENV_FALLBACK=false
SINGBOX_ENABLED=true
SINGBOX_BIN=data/bin/sing-box
PROXY_GATEWAY_BASE_PORT=18080

DOUBAO_ENABLED=true
ARK_API_KEY=your-ark-api-key-here
TMDB_API_KEY=your-tmdb-api-key-here
BANGUMI_ENABLED=true

ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码
ADMIN_EMAIL=admin@example.com
