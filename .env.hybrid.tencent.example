# ===== 腾讯云 2C4G 轻量（推荐省钱方案）=====
# 拓扑：轻量云 = Nginx + frp + PostgreSQL + Redis + COS 封面
#       本地 Windows = API + Beat + Worker×24
#
# 1. 轻量云执行 scripts/tencent-lightweight/setup-server.sh 安装 PG/Redis
# 2. 控制台创建 COS 桶，复制本文件为 .env.hybrid 并填写
# 3. 本地：.\scripts\init-hybrid-db.ps1  →  .\scripts\start-hybrid.ps1
# 详细步骤见 docs/TENCENT-LIGHTWEIGHT.md

LOCAL_MODE=false
SERVE_FRONTEND=true
APP_ENV=production
DEBUG=false

SECRET_KEY=请替换为至少32位随机字符串
JWT_SECRET_KEY=请替换为至少32位随机字符串
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATA_DIR=data

ENABLE_API_DOCS=false
# 绑定域名后填写：CORS_ORIGINS=https://你的域名

# ---------- PostgreSQL（腾讯云轻量自建，填轻量公网 IP）----------
# 安全组：5432 仅放行你本地宽带公网 IP
DATABASE_URL=postgresql+asyncpg://tiktok_monitor:请填写密码@你的轻量公网IP:5432/tiktok_monitor
DATABASE_URL_SYNC=postgresql://tiktok_monitor:请填写密码@你的轻量公网IP:5432/tiktok_monitor

# ---------- Redis（同机部署，DB0=Celery，DB1=代理池）----------
# 安全组：6379 仅放行你本地宽带公网 IP
REDIS_URL=redis://:请填写Redis密码@你的轻量公网IP:6379/0
PROXY_POOL_REDIS_DB=1

# ---------- 腾讯云 COS（封面 + PG 备份，S3 兼容）----------
# 地域与轻量一致，如广州：cos.ap-guangzhou.myqcloud.com
# 桶名格式：bucket名-APPID，如 tiktok-monitor-covers-1250000000
MINIO_ENDPOINT=cos.ap-guangzhou.myqcloud.com
MINIO_ACCESS_KEY=请填写CAM子账号SecretId
MINIO_SECRET_KEY=请填写CAM子账号SecretKey
MINIO_BUCKET=tiktok-monitor-covers-1250000000
MINIO_SECURE=true

# ---------- 双计算节点（本地 + 轻量#2）----------
COMPUTE_NODE_ID=local
COMPUTE_NODE_LABEL=本地电脑
BEAT_ENABLED_ON_NODE=false
CELERY_WORKER_NODE_PREFIX=local
CLUSTER_PEER_API_URL=http://你的轻量2公网IP:8000
CLUSTER_EXPECTED_WORKERS_LOCAL=24
CLUSTER_EXPECTED_WORKERS_CLOUD2=10
CLUSTER_NODE_LABEL_LOCAL=本地电脑
CLUSTER_NODE_LABEL_CLOUD2=轻量云 #2

# 轻量#2 上改为：COMPUTE_NODE_ID=cloud2 / BEAT_ENABLED_ON_NODE=true / CELERY_WORKER_NODE_PREFIX=cloud2
# 轻量#2 Worker 数建议 8~12（单独设 CELERY_WORKER_CONCURRENCY=10）

# ---------- Worker / 运维 ----------
CELERY_WORKER_CONCURRENCY=24
API_UVICORN_WORKERS=1

SNAPSHOT_RETENTION_DAYS=90
SNAPSHOT_PURGE_BATCH_SIZE=5000
POSTGRES_BACKUP_KEEP_LOCAL=7
POSTGRES_BACKUP_KEEP_REMOTE=14
POSTGRES_BACKUP_BUCKET_PREFIX=backups/postgres
# 本地 Beat 不跑 PG 备份（备份在轻量云 cron 执行，无需 Windows 装 pg_dump）
POSTGRES_BACKUP_ENABLED=false

# 超级管理员 Web 一键更新（集群监控页，仅更新本节点）
WEB_DEPLOY_UPDATE_ENABLED=true

SCRAPE_ALLOW_MOCK=false
SCRAPE_INTERVAL_MINUTES=1440
SCRAPE_REQUEST_DELAY_MIN=5
SCRAPE_REQUEST_DELAY_MAX=12
SCRAPE_MAX_RETRIES=3
SCRAPE_RETRY_INTERVAL_MINUTES=5
SCRAPE_PROXY_URL=

RECENT_VIDEO_DAYS=10
RECENT_VIDEO_UPDATE_DAYS=3
HISTORICAL_VIEW_THRESHOLD=100000
DAILY_HOT_VIEW_THRESHOLD=50000
DAILY_HOT_GROWTH_THRESHOLD=30
VIRAL_VIEW_THRESHOLD=100000

PROXY_POOL_ENABLED=true
PROXY_POOL_HEALTH_URL=https://www.tiktok.com
PROXY_POOL_BAD_TTL_SECONDS=1800
PROXY_POOL_MAX_FAIL_STREAK=3
PROXY_POOL_LOCAL_ENV_FALLBACK=false

SINGBOX_ENABLED=true
PROXY_GATEWAY_BASE_PORT=18080

DOUBAO_ENABLED=true
ARK_API_KEY=your-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-1-5-vision-pro-32k-250115
RECOGNITION_AUTO_TRIGGER=false

TMDB_API_KEY=your-tmdb-api-key-here
BANGUMI_ENABLED=true
BANGUMI_ACCESS_TOKEN=
BANGUMI_USER_AGENT=tiktok-monitor/1.0 (https://github.com/local/tiktok-monitor)

ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码
ADMIN_EMAIL=admin@example.com
